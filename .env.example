# AI service (OpenAI-compatible endpoint, e.g. z.ai, OpenAI, etc.)
CLAUDE_API_KEY=your_api_key_here
CLAUDE_BASE_URL=https://api.openai.com/v1

# Admin password for first login
AUTH_PASSWORD=change_me

# JWT secret — change this in production to a long random string
JWT_SECRET=change_me_to_random_string

# Jina Reader API key (optional) — used as a fallback for pages blocked by
# Cloudflare/anti-bot or that render content via JS. Get one at https://jina.ai
JINA_API_KEY=
